generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  gender    Gender
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
